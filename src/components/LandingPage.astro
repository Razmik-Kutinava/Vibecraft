---
import type { Lang } from "@/i18n/landing";
import { getLandingMessages, telegramChannelUrl, telegramDirectUrl } from "@/i18n/landing";
import HeroIsland from "@/components/hero/HeroIsland.tsx";
import logoVibecraft from "@/assets/logo_vibecraft.png?url";
import "@/styles/landing.css";

export interface BlogPreview {
  slug: string;
  emoji: string;
  title: string;
  description: string;
  tag: string;
  dateLabel: string;
  readLabel: string;
}

interface Props {
  lang: Lang;
  recentPosts: BlogPreview[];
}

const { lang, recentPosts } = Astro.props;
const m = getLandingMessages(lang);
const base = `/${lang}`;
const manifestLabel = lang === "ru" ? "Манифест" : "Manifesto";
const menuOpenLabel = lang === "ru" ? "Открыть меню" : "Open menu";
const menuCloseLabel = lang === "ru" ? "Закрыть меню" : "Close menu";
const menuNavLabel = lang === "ru" ? "Основная навигация" : "Main navigation";
---

<header class="header" data-menu-open-label={menuOpenLabel} data-menu-close-label={menuCloseLabel}>
  <div class="container nav-container">
    <input type="checkbox" id="nav-open" class="nav-toggle-input" tabindex="-1" />
    <div class="nav-bar">
      <div class="logo-brand">
        <a class="logo-link" href={base}>
          <img
            class="logo-img"
            src={logoVibecraft}
            alt="Vibecraft"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <span class="logo-tagline">{m.nav.tagline}</span>
        </a>
      </div>
      <label
        for="nav-open"
        class="nav-burger"
        id="nav-burger"
        tabindex="0"
        aria-controls="nav-panel"
        aria-expanded="false"
        aria-label={menuOpenLabel}
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </label>
    </div>
    <nav id="nav-panel" class="nav-panel" aria-label={menuNavLabel}>
      <label for="nav-open" class="nav-scrim"></label>
      <div class="nav-panel-inner">
        <a href="#why-us">{m.nav.benefits}</a>
        <a href="#services">{m.nav.services}</a>
        <a href="#process">{m.nav.process}</a>
        <a href="#cases">{m.nav.cases}</a>
        <a href={`${base}/blog`}>{m.nav.blog}</a>
        <a href={`${base}/manifest`}>{m.nav.manifest}</a>
        <a href="#contact">{m.nav.contact}</a>
        <a href={telegramChannelUrl} class="nav-tg" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
            ></path>
          </svg>
          <span>{m.nav.tgChannel}</span>
        </a>
        <div class="lang-switch">
          <a href="/ru/" class:list={[{ "is-active": lang === "ru" }]}>{m.nav.langRu}</a>
          <a href="/en/" class:list={[{ "is-active": lang === "en" }]}>{m.nav.langEn}</a>
        </div>
        <a href="#contact" class="btn btn-primary nav-cta">{m.nav.order}</a>
      </div>
    </nav>
  </div>
</header>

<main>
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <div class="hero-inner">
          <h1>{m.hero.h1}</h1>
          <p>{m.hero.lead}</p>
          <ul class="hero-bullets">
            {m.hero.bullets.map((line) => <li>{line}</li>)}
          </ul>
          <div class="hero-actions">
            <a href="#contact" class="btn btn-primary">{m.hero.ctaPrimary}</a>
            <a href={telegramDirectUrl} class="hero-tg-link" target="_blank" rel="noopener noreferrer">{m.hero.ctaTelegram}</a>
          </div>
        </div>
        <div class="hero-visual hidden lg:block" aria-hidden="true">
          <HeroIsland client:load />
        </div>
      </div>
    </div>
  </section>

  <section id="audience" class="section section--surface">
    <div class="container">
      <h2 class="section-title">{m.audience.title}</h2>
      <div class="audience-grid">
        {
          m.audience.cards.map((c) => (
            <div class:list={["card", "card--audience", c.featured ? "card--audience-featured" : null]}>
              <div class="card-audience-icon">{c.icon}</div>
              {c.subtitle ? <p class="card-audience-sub">{c.subtitle}</p> : null}
              <h3 class="card-audience-title">{c.title}</h3>
              <p>{c.body}</p>
            </div>
          ))
        }
      </div>
      <div class="audience-cta">
        <a href="#contact" class="btn btn-primary">
          {m.audience.cta}
        </a>
      </div>
    </div>
  </section>

  <section id="methodology" class="section">
    <div class="container">
      <h2 class="section-title">{m.methodology.title}</h2>
      <p class="methodology-lead">{m.methodology.lead}</p>
      <p class="methodology-intro">{m.methodology.intro}</p>
      <ul class="methodology-bullets">
        {m.methodology.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
      <div class="methodology-cta">
        <a href="#cases" class="btn btn-outline">
          {m.methodology.cta}
        </a>
      </div>
    </div>
  </section>

  <section id="why-us" class="section section--surface">
    <div class="container">
      <h2 class="section-title">{m.whyUs.title}</h2>
      <div class="why-grid">
        {
          m.whyUs.items.map((item) => (
            <div class="why-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="objections" class="section">
    <div class="container">
      <h2 class="section-title">{m.objections.title}</h2>
      <div class="objections-accordion">
        {
          m.objections.items.map((o) => (
            <details class="objection-details">
              <summary class="objection-summary">{o.q}</summary>
              <div class="objection-a-wrap">
                <p class="objection-a">{o.a}</p>
              </div>
            </details>
          ))
        }
      </div>
      <div class="objections-cta">
        <a href={telegramDirectUrl} class="hero-tg-link" target="_blank" rel="noopener noreferrer">
          {m.objections.ctaTelegram}
        </a>
      </div>
    </div>
  </section>

  <section id="services" class="section section--surface">
    <div class="container">
      <h2 class="section-title">{m.services.title}</h2>
      <div class="section-sub max-w-[52rem] mx-auto">{m.services.sub}</div>
      <div class="cards-grid cards-grid--services">
        {
          m.services.items.map((s) => (
            <div class="card card--service">
              <div class="card-icon">{s.icon}</div>
              <h3 class="card--service-title">{s.title}</h3>
              <div class="service-meta">
                {s.price}
                <span class="sep">·</span>
                {s.timeline}
              </div>
              <p class="card--service-desc">{s.desc}</p>
              <a href="#contact" class="btn btn-primary card--service-cta">
                {s.cta}
              </a>
            </div>
          ))
        }
      </div>
      <div class="services-custom">
        <p>{m.services.customHint}</p>
        <a href="#contact" class="btn btn-outline">
          {m.services.customCta}
        </a>
      </div>
    </div>
  </section>

  <section class="section mid-cta-band section--surface" aria-label={m.midCta.title}>
    <div class="container mid-cta-inner">
      <p class="mid-cta-title">{m.midCta.title}</p>
      <p class="mid-cta-sub">{m.midCta.sub}</p>
      <a href="#contact" class="btn btn-primary">{m.midCta.btn}</a>
    </div>
  </section>

  <section id="process" class="section">
    <div class="container">
      <h2 class="section-title">{m.process.title}</h2>
      <div class="process-steps">
        {
          m.process.steps.map((st, i) => (
            <div class="step">
              <div class="step-circle">{i + 1}</div>
              <h3 class="step-title">{st.title}</h3>
              <p class="step-desc">{st.desc}</p>
            </div>
          ))
        }
      </div>
      <div class="audience-cta">
        <a href="#contact" class="btn btn-primary">
          {m.process.cta}
        </a>
      </div>
    </div>
  </section>

  <section id="cases" class="section section--surface">
    <div class="container">
      <h2 class="section-title">{m.cases.title}</h2>
      <div class="cards-grid">
        {
          m.cases.items.map((c) => (
            <div class="case-card case-card--rich">
              <div class="card-icon">{c.icon}</div>
              <h3>{c.title}</h3>
              <p class="case-meta-line">{c.meta}</p>
              <p class="case-label">{lang === "ru" ? "Проблема" : "Problem"}</p>
              <p>{c.problem}</p>
              <p class="case-label">{lang === "ru" ? "Решение" : "Solution"}</p>
              <p>{c.solution}</p>
              <p class="case-result-line">📈 {lang === "ru" ? "Результат" : "Result"}: {c.result}</p>
              <a href={`${base}${c.readMoreHref}`} class="case-readmore">
                {c.readMore}
              </a>
            </div>
          ))
        }
      </div>
      <p class="cases-more">{m.cases.moreLabel}</p>
      <div class="cases-more-actions">
        <a href={`${base}/blog`} class="btn btn-outline">{m.blogSection.viewAll}</a>
      </div>
    </div>
  </section>

  <section id="testimonials" class="section">
    <div class="container">
      <h2 class="section-title">{m.testimonials.title}</h2>
      <div class="testimonial-note">
        <p>{m.testimonials.note}</p>
      </div>
    </div>
  </section>

  <section id="manifest" class="section section--surface">
    <div class="container">
      <h2 class="section-title">{m.manifestTeaser.title}</h2>
      <div class="manifest-teaser">
        {m.manifestTeaser.paragraphs.map((p) => <p>{p}</p>)}
        {
          m.manifestTeaser.pillars.map((pillar) => (
            <div class="manifest-pillar">
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
            </div>
          ))
        }
        <p class="manifest-fit">{m.manifestTeaser.fit}</p>
        <p class="manifest-fit">{m.manifestTeaser.notFit}</p>
        <p class="manifest-fit">{m.manifestTeaser.closing}</p>
        <div class="manifest-teaser-actions">
          <a href={`${base}/manifest`} class="btn btn-outline">
            {m.manifestTeaser.linkLabel}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="blog" class="section">
    <div class="container">
      <h2 class="section-title">{m.blogSection.title}</h2>
      <div class="section-sub">{m.blogSection.sub}</div>
      <div class="cards-grid">
        {
          recentPosts.map((post) => (
            <a href={`${base}/blog/${post.slug}`} class="blog-card">
              <div class="blog-image">{post.emoji}</div>
              <div class="blog-content">
                <span class="blog-tag">{post.tag}</span>
                <h3 class="blog-title">{post.title}</h3>
                <p class="blog-desc">{post.description}</p>
                <div class="blog-meta">
                  <span>📅 {post.dateLabel}</span>
                  <span>⏱ {post.readLabel}</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="blog-section-actions">
        <a href={`${base}/blog`} class="btn btn-primary">{m.blogSection.viewAll}</a>
      </div>
    </div>
  </section>

  <section id="contact" class="section section--surface">
    <div class="container">
      <div class="form-card">
        <h2 class="section-title">{m.contact.title}</h2>
        <p class="contact-sub">{m.contact.sub}</p>
        <form action="https://formspree.io/f/xkgnnkjq" method="POST">
          <input type="hidden" name="lang" value={lang} />
          <div class="form-group">
            <label class="sr-only" for="contact-name">{m.contact.namePh}</label>
            <input id="contact-name" type="text" name="name" placeholder={m.contact.namePh} autocomplete="name" required />
          </div>
          <div class="form-group">
            <label class="sr-only" for="contact-email">{m.contact.contactPh}</label>
            <input
              id="contact-email"
              type="text"
              name="contact"
              placeholder={m.contact.contactPh}
              autocomplete="email"
              required
            />
          </div>
          <div class="form-group">
            <label class="sr-only" for="contact-message">{m.contact.messagePh}</label>
            <textarea id="contact-message" name="message" rows="4" placeholder={m.contact.messagePh} />
          </div>
          <button type="submit" class="btn btn-primary w-full justify-center">{m.contact.submit}</button>
          <p class="contact-privacy">{m.contact.privacy}</p>
        </form>
        <p class="contact-fast-tg">
          <a href={telegramDirectUrl} target="_blank" rel="noopener noreferrer">{m.contact.fastTg}</a>
        </p>
      </div>
    </div>
  </section>
</main>

<div class="sticky-cta-bar">
  <a href="#contact" class="btn btn-primary sticky-cta-btn">{m.midCta.btn}</a>
</div>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-logo-row">
          <a class="footer-logo-block" href={base}>
            <img
              class="footer-logo-img"
              src={logoVibecraft}
              alt=""
              loading="lazy"
              decoding="async"
            />
            <span class="footer-logo-sub">{m.footer.taglineSub}</span>
          </a>
        </div>
        <p class="footer-motto">{m.footer.motto}</p>
      </div>
      <div class="footer-links">
        <h4>{m.footer.navCol}</h4>
        <a href="#services">{m.nav.services}</a>
        <a href="#cases">{m.nav.cases}</a>
        <a href="#process">{m.nav.process}</a>
        <a href={`${base}/manifest`}>{manifestLabel}</a>
        <a href={`${base}/blog`}>{m.nav.blog}</a>
        <a href="#contact">{m.nav.contact}</a>
      </div>
      <div class="footer-links">
        <h4>{m.footer.contactsCol}</h4>
        <a href={`mailto:${m.footer.email}`}>{m.footer.email}</a>
        <a href={telegramDirectUrl} target="_blank" rel="noopener noreferrer">{m.footer.tgDirect}</a>
        <a href={telegramChannelUrl} target="_blank" rel="noopener noreferrer">{m.footer.tgChannel}</a>
      </div>
    </div>
    <div class="copyright">© {new Date().getFullYear()} Vibecraft. {m.footer.rights}</div>
  </div>
</footer>

<script is:inline>
  const navToggle = document.getElementById("nav-open");
  const burger = document.getElementById("nav-burger");
  const headerEl = document.querySelector("header.header");
  const labelOpen = headerEl?.dataset.menuOpenLabel ?? "Open menu";
  const labelClose = headerEl?.dataset.menuCloseLabel ?? "Close menu";

  function syncNavAria() {
    if (!navToggle || !burger) return;
    const open = navToggle.checked;
    burger.setAttribute("aria-expanded", open ? "true" : "false");
    burger.setAttribute("aria-label", open ? labelClose : labelOpen);
  }

  navToggle?.addEventListener("change", syncNavAria);
  syncNavAria();

  document.querySelectorAll(".nav-panel-inner a").forEach((link) => {
    link.addEventListener("click", () => {
      if (navToggle) navToggle.checked = false;
      syncNavAria();
    });
  });
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      const id = this.getAttribute("href");
      if (!id || id === "#") return;
      const target = document.querySelector(id);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
