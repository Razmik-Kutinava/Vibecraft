---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { getLandingMessages, type Lang } from "@/i18n/landing";
import { defaultOgImage, getSiteUrl } from "@/lib/site";
import { breadcrumbList, organizationNode } from "@/lib/schema";
import { formatPostDate, readTimeLabel } from "@/lib/formatDate";
import { isCaseStudyPost } from "@/lib/caseStudy";

export function getStaticPaths() {
  return [{ params: { lang: "ru" } }, { params: { lang: "en" } }];
}

const raw = Astro.params.lang;
const lang = (raw === "ru" || raw === "en" ? raw : "ru") as Lang;
const m = getLandingMessages(lang);
const site = getSiteUrl();
const c = m.casesList;

const posts = await getCollection("blog", (e) => e.id.startsWith(`${lang}/`));
const casePosts = posts.filter((p) => isCaseStudyPost(p.data.tag));
const sorted = casePosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const graph = [
  organizationNode(site),
  breadcrumbList(site, [
    { name: lang === "ru" ? "Главная" : "Home", path: `/${lang}/` },
    { name: c.h1, path: `/${lang}/cases` },
  ]),
];

const canonicalPath = `/${lang}/cases`;
const alternates = [
  { hreflang: "ru", href: new URL("/ru/cases", site).href },
  { hreflang: "en", href: new URL("/en/cases", site).href },
  { hreflang: "x-default", href: new URL("/ru/cases", site).href },
];
---

<Layout
  title={c.title}
  description={c.description}
  keywords={c.keywords}
  canonicalPath={canonicalPath}
  ogImage={defaultOgImage}
  htmlLang={lang}
  ogLocale={lang === "ru" ? "ru_RU" : "en_US"}
  ogLocaleAlternate={lang === "ru" ? ["en_US"] : ["ru_RU"]}
  alternates={alternates}
  jsonLd={graph}
  bodyClass="min-h-screen bg-background text-foreground font-sans antialiased"
>
  <main class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
    <a
      href={`/${lang}/`}
      class="inline-flex rounded-[var(--radius)] border border-line px-4 py-2 text-sm text-muted-foreground transition hover:border-neon/40 hover:text-foreground"
    >
      {c.back}
    </a>
    <header class="mt-8">
      <p class="font-mono text-xs uppercase tracking-widest text-neon">Vibecraft</p>
      <h1 class="mt-3 text-4xl font-bold text-foreground">{c.h1}</h1>
      <p class="mt-3 text-muted-foreground leading-relaxed">{c.sub}</p>
    </header>

    {
      sorted.length === 0 ? (
        <p class="mt-10 text-muted-foreground">{c.empty}</p>
      ) : (
        <ul class="mt-10 space-y-4">
          {sorted.map((post) => {
            const slug = post.id.replace(`${lang}/`, "").replace(/\.md$/i, "");
            return (
              <li>
                <a
                  href={`/${lang}/blog/${slug}`}
                  class="block rounded-2xl border border-line bg-surface p-5 transition-colors hover:border-neon/40"
                >
                  <span class="text-xl">{post.data.emoji ?? "💡"}</span>
                  <span class="ml-2 rounded-[var(--radius)] border border-neon/30 px-2 py-0.5 font-mono text-xs font-semibold text-neon">
                    {post.data.tag}
                  </span>
                  <h2 class="mt-2 text-xl font-semibold text-foreground">{post.data.title}</h2>
                  <p class="mt-1 text-sm text-muted-foreground">{post.data.description}</p>
                  <p class="mt-3 font-mono text-xs text-muted-foreground/90">
                    📅 {formatPostDate(post.data.date, lang)} · ⏱ {readTimeLabel(post.data.readMinutes, lang)}
                  </p>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }

    <p class="mt-10">
      <a
        href={`/${lang}/blog`}
        class="inline-flex rounded-[var(--radius)] border border-line px-4 py-2 text-sm font-medium text-foreground transition hover:border-neon/40"
      >
        {c.viewBlog}
      </a>
    </p>
  </main>
</Layout>
