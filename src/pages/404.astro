---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="404 — страница не найдена | Vibecraft"
  description="Запрашиваемая страница не существует."
  canonicalPath="/404"
  robots="noindex, nofollow"
  htmlLang="ru"
  bodyClass="min-h-screen bg-background text-foreground font-sans antialiased"
>
  <main class="mx-auto flex max-w-lg flex-col items-center justify-center px-4 py-24 text-center">
    <p class="font-mono text-sm uppercase tracking-widest text-neon">404</p>
    <h1 class="mt-4 text-3xl font-bold text-foreground">Страница не найдена</h1>
    <p class="mt-3 text-muted-foreground">Проверьте адрес или вернитесь на главную.</p>
    <a
      href="/ru/"
      class="mt-8 inline-flex rounded-[var(--radius)] bg-neon px-8 py-3 font-mono text-sm font-bold tracking-wide text-primary-foreground no-underline transition hover:bg-neon-dim"
    >
      На главную
    </a>
  </main>
</Layout>
