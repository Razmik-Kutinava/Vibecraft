---
import Layout from "@/layouts/Layout.astro";

/** Локализация по префиксу пути: /en/* → EN, иначе RU */
const pathname = Astro.url.pathname;
const isEn = pathname.startsWith("/en");
const title = isEn
  ? "404 — Page not found | Vibecraft"
  : "404 — страница не найдена | Vibecraft";
const description = isEn
  ? "The requested page does not exist."
  : "Запрашиваемая страница не существует.";
const homeHref = isEn ? "/en/" : "/ru/";
const homeLabel = isEn ? "Home" : "На главную";
const h1 = isEn ? "Page not found" : "Страница не найдена";
const lead = isEn
  ? "Check the URL or return to the homepage."
  : "Проверьте адрес или вернитесь на главную.";
---

<Layout
  title={title}
  description={description}
  canonicalPath="/404"
  robots="noindex, nofollow"
  htmlLang={isEn ? "en" : "ru"}
  bodyClass="min-h-screen bg-background text-foreground font-sans antialiased"
>
  <main class="mx-auto flex max-w-lg flex-col items-center justify-center px-4 py-24 text-center">
    <p class="font-mono text-sm uppercase tracking-widest text-neon">404</p>
    <h1 class="mt-4 text-3xl font-bold text-foreground">{h1}</h1>
    <p class="mt-3 text-muted-foreground">{lead}</p>
    <a
      href={homeHref}
      class="mt-8 inline-flex rounded-[var(--radius)] bg-neon px-8 py-3 font-mono text-sm font-bold tracking-wide text-primary-foreground no-underline transition hover:bg-neon-dim"
    >
      {homeLabel}
    </a>
  </main>
</Layout>
